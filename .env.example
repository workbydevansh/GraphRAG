# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_PATH=./data/benchmark_lab.sqlite
CORPUS_PATH=./data/processed/corpus.jsonl
EVAL_SET_PATH=./data/eval/eval_set.json
CHROMA_PATH=./data/indexes/chroma

# LLM provider: mock, openai, openai_compatible, or ollama
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_TEMPERATURE=0
INPUT_COST_PER_1K=0.00015
OUTPUT_COST_PER_1K=0.0006

# Evaluation
ENABLE_HF_EVAL=true
ENABLE_LLM_JUDGE=true
BERTSCORE_MODEL=microsoft/deberta-xlarge-mnli

# TigerGraph GraphRAG through pyTigerGraph
TIGERGRAPH_HOST=http://localhost
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=
TIGERGRAPH_SECRET=
TIGERGRAPH_GRAPH_NAME=TigerGraphRAG
TIGERGRAPH_RESTPP_PORT=14240

# TigerGraph GraphRAG service URL. If unset, the GraphRAG pipeline uses labelled dev mode.
TIGERGRAPH_GRAPHRAG_URL=
TIGERGRAPH_GRAPHRAG_API_KEY=
TIGERGRAPH_GRAPHRAG_PATH=/query
TIGERGRAPH_METHOD=hybrid
